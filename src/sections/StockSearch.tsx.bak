import React, { useState } from 'react';
import { useStock } from '../contexts/StockContext';

const popularStocks = [
  { symbol: '513310', name: '中韩半导体 ETF' },
  { symbol: '600519', name: '贵州茅台' },
  { symbol: '000858', name: '五粮液' },
  { symbol: '300750', name: '宁德时代' },
  { symbol: '002594', name: '比亚迪' },
  { symbol: '510300', name: '沪深 300ETF' }
];

interface StockSearchProps {
  onStartAnalysis: (symbol: string, name: string) => void;
}

export default function StockSearch({ onStartAnalysis }: StockSearchProps) {
  const [symbol, setSymbol] = useState('');
  const [name, setName] = useState('');
  const { isLoading } = useStock();

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (symbol.trim()) {
      onStartAnalysis(symbol.trim(), name.trim());
    }
  };

  const handleQuickSelect = (stock: typeof popularStocks[0]) => {
    onStartAnalysis(stock.symbol, stock.name);
  };

  return (
    <div className="min-h-screen gradient-bg">
      {/* Header with Logo */}
      <header className="bg-white border-b border-gray-200">
        <div className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div className="flex items-center gap-3">
            {/* Professional Logo - Clean, no AI clichés */}
            <div className="w-10 h-10 bg-primary rounded-lg flex items-center justify-center shadow-sm">
              <span className="text-white font-bold text-base">DR</span>
            </div>
            <div>
              <h1 className="text-xl font-semibold text-gray-900 leading-tight">Danny Road</h1>
              <p className="text-xs text-gray-500">专业股票分析终端</p>
            </div>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        {/* Hero Section - Clear value proposition */}
        <div className="text-center mb-12 animate-fade-in">
          <h2 className="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            股票智能分析系统
          </h2>
          <p className="text-lg text-gray-600 max-w-2xl mx-auto">
            基于量化模型的专业股票分析工具，提供买卖点决策、技术面分析和走势预测
          </p>
        </div>

        {/* Search Form - Primary action */}
        <form onSubmit={handleSubmit} className="mb-12 animate-slide-in">
          <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div className="flex flex-col md:flex-row gap-4">
              <div className="flex-1">
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  股票代码
                </label>
                <input
                  type="text"
                  value={symbol}
                  onChange={(e) => setSymbol(e.target.value)}
                  placeholder="例如：513310, 600519"
                  className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-base"
                  disabled={isLoading}
                />
              </div>
              <div className="flex-1">
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  股票名称（可选）
                </label>
                <input
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="例如：中韩半导体 ETF"
                  className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-base"
                  disabled={isLoading}
                />
              </div>
              <div className="flex items-end">
                <button
                  type="submit"
                  disabled={!symbol.trim() || isLoading}
                  className="w-full md:w-auto px-8 py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-medium btn-hover disabled:opacity-50 disabled:cursor-not-allowed transition-all shadow-sm"
                >
                  {isLoading ? '分析中...' : '开始分析'}
                </button>
              </div>
            </div>
            <p className="mt-3 text-sm text-gray-500">
              💡 提示：输入股票代码后按回车键快速开始
            </p>
          </div>
        </form>

        {/* Popular Stocks - Quick access */}
        <div className="animate-slide-in" style={{ animationDelay: '0.1s' }}>
          <div className="flex items-center gap-3 mb-6">
            <h3 className="text-lg font-semibold text-gray-900">热门股票</h3>
            <div className="flex-1 h-px bg-gray-200"></div>
          </div>
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
            {popularStocks.map((stock, index) => (
              <button
                key={stock.symbol}
                onClick={() => handleQuickSelect(stock)}
                disabled={isLoading}
                className="stock-card text-left disabled:opacity-50 disabled:cursor-not-allowed"
                style={{ animationDelay: `${index * 0.05}s` }}
              >
                <div className="flex items-start justify-between mb-2">
                  <div className="text-base font-semibold text-primary">
                    {stock.symbol}
                  </div>
                </div>
                <div className="text-sm text-gray-600 truncate" title={stock.name}>
                  {stock.name}
                </div>
              </button>
            ))}
          </div>
        </div>

        {/* Features - Three column layout for better visual flow */}
        <div className="mt-16 animate-slide-in" style={{ animationDelay: '0.2s' }}>
          <div className="flex items-center gap-3 mb-6">
            <h3 className="text-lg font-semibold text-gray-900">核心功能</h3>
            <div className="flex-1 h-px bg-gray-200"></div>
          </div>
          <div className="grid md:grid-cols-3 gap-6">
            <div className="bg-white rounded-lg border border-gray-200 p-6 hover:border-primary-light transition-colors">
              <div className="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4">
                <svg className="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
                </svg>
              </div>
              <h4 className="font-semibold text-gray-900 mb-2">专业 K 线图</h4>
              <p className="text-sm text-gray-600">
                4 小时 K 线图，360 天历史数据，自动标注关键价位（止盈/止损）
              </p>
            </div>
            
            <div className="bg-white rounded-lg border border-gray-200 p-6 hover:border-primary-light transition-colors">
              <div className="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4">
                <svg className="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <h4 className="font-semibold text-gray-900 mb-2">五维决策引擎</h4>
              <p className="text-sm text-gray-600">
                趋势 + 位置 + 盈亏比 + 动量 + 情绪，智能计算最佳买卖点
              </p>
            </div>
            
            <div className="bg-white rounded-lg border border-gray-200 p-6 hover:border-primary-light transition-colors">
              <div className="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4">
                <svg className="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <h4 className="font-semibold text-gray-900 mb-2">一周预测</h4>
              <p className="text-sm text-gray-600">
                蒙特卡洛模拟 10,000 次，概率化预测未来走势
              </p>
            </div>
          </div>
        </div>
      </main>

      {/* Footer */}
      <footer className="border-t border-gray-200 mt-16">
        <div className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <p className="text-center text-sm text-gray-500">
            © 2026 Danny Road. Professional Stock Analysis Terminal.
          </p>
          <p className="mt-2 text-center text-xs text-gray-400">
            ⚠️ 风险提示：以上分析仅供参考，不构成投资建议。市场有风险，投资需谨慎。
          </p>
        </div>
      </footer>
    </div>
  );
}
