/**
 * SectorService - 热门板块服务
 * 使用统一 API 客户端，避免重复代码和硬编码 URL
 * 
 * @module services/SectorService
 * @version 2.0.0
 */

import { StockConfig } from '../config/stock.config';
import { Sector, HotSector } from '../models/sector.model';
import { apiClient, ApiResponse } from './ApiClient';
import { logger } from '../utils/logger';
import { AppError, ErrorCode } from '../utils/errors';

interface CacheItem<T> {
  data: T;
  timestamp: number;
}

export class SectorService {
  private readonly API_BASE = StockConfig.DATA_SOURCES.EASTMONEY.BASE_URL;
  private cache: Map<string, CacheItem<HotSector[]>> = new Map();
  
  async getHotSectors(): Promise<HotSector[]> {
    const cacheKey = 'hot_sectors';
    const cached = this.cache.get(cacheKey);
    
    if (cached && Date.now() - cached.timestamp < StockConfig.HOT_SECTORS.UPDATE_INTERVAL * 1000) {
      logger.info('[SectorService] 使用缓存数据');
      return cached.data;
    }

    try {
      const sectors = await this.fetchSectorData();
      const filteredSectors = this.filterHotSectors(sectors);
      const hotSectors = this.sortAndLimitSectors(filteredSectors);
      
      await this.fetchConstituentsForSectors(hotSectors);
      
      this.cache.set(cacheKey, { data: hotSectors, timestamp: Date.now() });
      
      return hotSectors;
    } catch (error) {
      logger.error('[SectorService] 获取热门板块失败', error);
      
      if (cached) {
        logger.warn('[SectorService] 返回过期缓存数据');
        return cached.data;
      }
      
      throw error instanceof AppError 
        ? error 
        : new AppError(ErrorCode.API_ERROR, '获取热门板块失败', { originalError: String(error) });
    }
  }

  private async fetchConstituentsForSectors(sectors: HotSector[]): Promise<void> {
    for (const sector of sectors) {
      try {
        const constituents = await this.fetchSectorConstituents(sector.code);
        sector.topStocks = constituents.slice(0, 6).map(stock => ({
          code: stock.code,
          name: stock.name,
          changePercent: stock.changePercent
        }));
      } catch (e) {
        logger.warn(`[SectorService] 获取${sector.name}成分股失败`, e);
        sector.topStocks = [];
      }
    }
  }

  private async fetchSectorData(): Promise<Sector[]> {
    const params = new URLSearchParams({
      pn: '1', pz: '20', po: '1', np: '1', fltt: '2', invt: '2',
      fid: 'f62', fs: 'm:90+t:2', fields: 'f12,f14,f3,f62,f8,f20,f184'
    });
    const url = `${this.API_BASE}/sector?${params.toString()}`;

    const response: ApiResponse<any> = await apiClient.getWithRetry(url, {
      timeout: 10000, retries: 3, retryDelay: 1000
    });

    if (!response.success || !response.data?.data?.diff) {
      throw new AppError(ErrorCode.API_ERROR, response.error || '获取板块数据失败');
    }

    return Object.values(response.data.data.diff).map((s: any) => ({
      code: s.f12, name: s.f14, changePercent: Number(s.f3) || 0,
      heatScore: Math.min(100, Math.max(0, 50 + Number(s.f3 || 0) * 2)),
      capitalInflow: Number(s.f62) || 0, mainCapitalInflow: Number(s.f62) || 0,
      turnoverRate: Number(s.f8) || 0, marketValue: Number(s.f20) || 0,
      rsi: Number(s.f184) || 50, momentumScore: Math.min(100, Math.max(0, 50 + Number(s.f3 || 0) * 2)),
      consecutiveDays: 1, source: 'eastmoney', timestamp: new Date().toISOString()
    }));
  }

  private filterHotSectors(sectors: Sector[]): Sector[] {
    return sectors.filter(sector => 
      sector.heatScore >= StockConfig.HOT_SECTORS.MIN_HEAT_SCORE &&
      sector.mainCapitalInflow >= StockConfig.HOT_SECTORS.MIN_CAPITAL_INFLOW &&
      sector.mainCapitalInflow > 0
    );
  }

  private sortAndLimitSectors(sectors: Sector[]): HotSector[] {
    return sectors
      .sort((a, b) => this.calculateSectorScore(b) - this.calculateSectorScore(a))
      .slice(0, StockConfig.HOT_SECTORS.TOP_N)
      .map(sector => this.enrichSectorData(sector));
  }

  private calculateSectorScore(sector: Sector): number {
    const normalizedHeat = sector.heatScore / 100;
    const normalizedCapital = Math.min(sector.mainCapitalInflow / 5000000000, 1);
    const normalizedMomentum = sector.momentumScore || 0.5;
    return (normalizedHeat * 0.4 + normalizedCapital * 0.4 + normalizedMomentum * 0.2) * 100;
  }

  private enrichSectorData(sector: Sector): HotSector {
    const changeScore = Math.min(100, Math.max(0, 50 + sector.changePercent * 5));
    const rsiScore = Math.min(100, Math.max(0, sector.rsi));
    const momentumScore = changeScore * 0.6 + rsiScore * 0.4;
    
    let capitalScore = 20;
    if (sector.mainCapitalInflow > 1e9) capitalScore = 100;
    else if (sector.mainCapitalInflow > 5e8) capitalScore = 80;
    else if (sector.mainCapitalInflow > 1e8) capitalScore = 60;
    else if (sector.mainCapitalInflow > 0) capitalScore = 40;
    
    const technicalScore = Math.min(100, sector.turnoverRate * 10);
    const fundamentalScore = Math.min(100, Math.log10(Math.max(1, sector.marketValue / 1e8)) * 15);
    
    const totalScore = Math.round(momentumScore * 0.30 + capitalScore * 0.35 + technicalScore * 0.20 + fundamentalScore * 0.15);
    
    let trend: HotSector['trend'] = '观察';
    if (totalScore >= 80 && sector.changePercent > 3 && sector.mainCapitalInflow > 5e8) trend = '强势热点';
    else if (totalScore >= 70 && sector.mainCapitalInflow > 1e8) trend = '持续热点';
    else if (sector.changePercent > 5 && sector.mainCapitalInflow > 0) trend = '新兴热点';
    else if (sector.changePercent < -3 || sector.mainCapitalInflow < -5e8) trend = '降温';
    
    return {
      ...sector, score: totalScore, isHotSpot: sector.heatScore >= 70, isContinuousHot: sector.consecutiveDays >= 3,
      recommendation: sector.heatScore >= 80 ? '强烈关注' : sector.heatScore >= 70 ? '重点关注' : sector.heatScore >= 60 ? '谨慎关注' : '一般关注',
      dimensions: { momentum: Math.round(momentumScore), capital: Math.round(capitalScore), technical: Math.round(technicalScore), fundamental: Math.round(fundamentalScore) },
      trend, topStocks: []
    };
  }

  private async fetchSectorConstituents(sectorCode: string): Promise<Array<{code: string; name: string; changePercent: number}>> {
    const params = new URLSearchParams({
      pn: '1', pz: '20', po: '1', np: '1', fltt: '2', invt: '2',
      fid: 'f12', fs: `b:${sectorCode}`, fields: 'f12,f14,f3'
    });
    const url = `${this.API_BASE}/sector?${params.toString()}`;

    const response: ApiResponse<any> = await apiClient.getWithRetry(url, {
      timeout: 10000, retries: 3, retryDelay: 1000
    });

    if (!response.success || !response.data?.data?.diff) {
      throw new AppError(ErrorCode.API_ERROR, response.error || '获取成分股失败');
    }

    return Object.values(response.data.data.diff).map((item: any) => ({
      code: item.f12 as string, name: item.f14 as string, changePercent: Number(item.f3) || 0
    }));
  }

  clearCache(): void {
    this.cache.clear();
  }
}

export const sectorService = new SectorService();
