# Test Environment Configuration
VITE_APP_ENV=test
VITE_APP_NAME=Sonata Stock Analysis (Test)
VITE_APP_VERSION=2.5.0-test

# API Configuration
VITE_API_TIMEOUT=5000
VITE_API_RETRY_COUNT=1
VITE_API_CACHE_ENABLED=false
VITE_API_CACHE_TTL=0

# Feature Flags
VITE_FEATURE_REALTIME_DATA=false
VITE_FEATURE_AUTO_UPDATE=false
VITE_FEATURE_DEBUG_LOGGING=true

# Performance
VITE_PERF_DEBOUNCE_DELAY=0
VITE_PERF_THROTTLE_DELAY=0
VITE_PERF_MAX_CONCURRENT=20

# Test Configuration
VITE_TEST_MOCK_API=true
VITE_TEST_COVERAGE=true
