# Development Environment Configuration
VITE_APP_ENV=development
VITE_APP_NAME=Sonata Stock Analysis (Dev)
VITE_APP_VERSION=2.5.0-dev

# API Configuration
VITE_API_TIMEOUT=10000
VITE_API_RETRY_COUNT=3
VITE_API_CACHE_ENABLED=true
VITE_API_CACHE_TTL=30000

# Feature Flags
VITE_FEATURE_REALTIME_DATA=true
VITE_FEATURE_AUTO_UPDATE=false
VITE_FEATURE_DEBUG_LOGGING=true

# Performance
VITE_PERF_DEBOUNCE_DELAY=100
VITE_PERF_THROTTLE_DELAY=50
VITE_PERF_MAX_CONCURRENT=10
